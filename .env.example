# Copy this file to .env.local and fill in your Supabase project's values
# (Supabase dashboard -> Project Settings -> API). .env.local is gitignored —
# never commit real keys.

# ---------------------------------------------------------------------------
# Required to run the app
# ---------------------------------------------------------------------------

# Project Settings -> API -> Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Project Settings -> API -> Project API keys -> anon / public
# Safe to expose to the app — access is enforced by row-level security
# (see supabase/schema.sql), not by keeping this key secret.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Only required for `npm run seed`
# ---------------------------------------------------------------------------

# Project Settings -> API -> Project API keys -> service_role
# DANGER: bypasses row-level security entirely. Used only by scripts/seed.mjs
# (a local Node script, not the app bundle). Never prefix this with
# EXPO_PUBLIC_ — that would ship it inside the app and expose full database
# access to every user.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Credentials for the test account scripts/seed.mjs creates/reuses. Optional —
# defaults to seed@tellbilly.test / tellbilly-seed-password if unset.
SEED_USER_EMAIL=seed@tellbilly.test
SEED_USER_PASSWORD=tellbilly-seed-password
